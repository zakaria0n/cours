<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/timerFinishedRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:visibility="gone"
    android:focusable="false"
    android:focusableInTouchMode="false">

    <LinearLayout
        android:layout_width="560dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/timer_card_background"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/timer_finished"
            android:textColor="@color/younes_navy_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/timer_finished_subtitle"
            android:textColor="@color/younes_text_secondary"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/timerFinishedAdd5"
                style="@style/ControlButton"
                android:nextFocusLeft="@id/timerFinishedRestart"
                android:text="@string/timer_add_5min" />

            <View
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/timerFinishedFinish"
                style="@style/ControlButton"
                android:background="@drawable/timer_button_danger_selector"
                android:text="@string/timer_finish" />

            <View
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/timerFinishedRestart"
                style="@style/ControlButton"
                android:nextFocusRight="@id/timerFinishedAdd5"
                android:text="@string/timer_restart" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
