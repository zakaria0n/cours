<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/younes_background">

    <!-- Top bar: logo left, title + filters right -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/top_bar_background"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="40dp"
        android:paddingTop="20dp"
        android:paddingEnd="40dp"
        android:paddingBottom="20dp">

        <!-- Small horizontal logo on the left -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_younes_horizontal" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Subject title + exam count on the right area -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="32dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/subjectTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/younes_navy_dark"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/examCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/younes_text_secondary"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Filter buttons -->
        <LinearLayout
            android:id="@+id/filterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:nextFocusDown="@id/examList"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnFilterAll"
                style="@style/ControlButton"
                android:text="@string/filter_all"
                android:textSize="14sp" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/btnFilterSujet"
                style="@style/ControlButton"
                android:text="@string/filter_sujet"
                android:textSize="14sp" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/btnFilterCorrection"
                style="@style/ControlButton"
                android:text="@string/filter_correction"
                android:textSize="14sp" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/btnFilterFavorites"
                style="@style/ControlButton"
                android:text="@string/filter_favorites"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom border of top bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:layout_marginTop="92dp"
        android:background="@color/younes_border" />

    <!-- Exam list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/examList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:clipToPadding="false"
        android:paddingStart="40dp"
        android:paddingTop="110dp"
        android:paddingEnd="40dp"
        android:paddingBottom="48dp" />

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/loading_bg"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:indeterminateTint="@color/younes_cyan" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_exams"
            android:textColor="@color/younes_text_secondary"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Error / empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/loading_bg"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/younes_text_secondary"
            android:textSize="20sp"
            android:text="@string/no_exams" />

        <TextView
            android:id="@+id/btnRetry"
            style="@style/ControlButton"
            android:layout_marginTop="20dp"
            android:text="@string/retry"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Help hint -->
    <TextView
        android:id="@+id/helpHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp"
        android:text="@string/help_exam_list"
        android:textColor="@color/younes_text_secondary"
        android:textSize="14sp"
        android:alpha="0.7" />

    <!-- Bottom cyan accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:background="@color/younes_cyan" />

</FrameLayout>
