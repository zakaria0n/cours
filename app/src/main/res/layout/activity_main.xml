<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/younes_pdf_bg">

    <!-- PDF full screen -->
    <com.younes.app.PdfViewerView
        android:id="@+id/pdfViewer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="false" />

    <!-- Top bar: white background with subtle bottom border -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="@drawable/top_bar_background"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="visible">

        <!-- Logo icon on left -->
        <ImageView
            android:id="@+id/logoIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center_vertical"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_younes_icon" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Younes"
            android:textColor="@color/younes_navy_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Page indicator on right -->
        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:textColor="@color/younes_navy_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Zoom indicator (hidden by default, centered) -->
    <TextView
        android:id="@+id/zoomIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:background="@drawable/zoom_indicator_bg"
        android:elevation="6dp"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="10dp"
        android:textColor="@color/younes_cyan"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Error message center -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="@color/text_error"
        android:textSize="22sp"
        android:visibility="gone" />

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/loading_bg"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:indeterminateTint="@color/younes_cyan" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_text"
            android:textColor="@color/younes_text_secondary"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Aide discrète, sans barre de boutons -->
    <TextView
        android:id="@+id/helpHintText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="12dp"
        android:text="@string/help_hint_bar"
        android:textColor="@color/younes_text_secondary"
        android:textSize="14sp"
        android:alpha="0.85"
        android:visibility="gone" />

    <!-- Help overlay (hidden by default) -->
    <LinearLayout
        android:id="@+id/helpOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/loading_bg"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/help_title"
            android:textColor="@color/younes_navy_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="10dp"
            android:text="@string/help_content"
            android:textColor="@color/younes_text_secondary"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Timer floating button (top-right area) -->
    <include
        layout="@layout/timer_floating_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginStart="16dp"
        android:layout_marginTop="64dp"
        android:layout_marginEnd="24dp"
        android:elevation="6dp" />

    <!-- Timer panel overlay -->
    <include layout="@layout/timer_panel" />

    <!-- Timer finished overlay -->
    <include layout="@layout/timer_finished_overlay" />

    <!-- Timer duration picker -->
    <include layout="@layout/timer_duration_picker" />

    <!-- Scroll up/down buttons (visible only when zoomed) -->
    <LinearLayout
        android:id="@+id/scrollButtons"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="56dp"
        android:background="@drawable/scroll_buttons_bg"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:alpha="0.9">

        <TextView
            android:id="@+id/btnScrollUp"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="▲"
            android:textColor="@color/younes_navy_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/button_focused" />

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:background="@color/younes_border"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnScrollDown"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="▼"
            android:textColor="@color/younes_navy_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:background="@drawable/button_focused" />

    </LinearLayout>

</FrameLayout>
