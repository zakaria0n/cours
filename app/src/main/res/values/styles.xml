<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Younes" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorBackground">@color/younes_white</item>
        <item name="android:windowBackground">@color/younes_white</item>
        <item name="android:statusBarColor">@color/younes_white</item>
        <item name="android:navigationBarColor">@color/younes_white</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.Younes.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/younes_white</item>
        <item name="android:colorBackground">@color/younes_white</item>
        <item name="android:statusBarColor">@color/younes_white</item>
        <item name="android:navigationBarColor">@color/younes_white</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="ControlButton" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/button_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textColor">@color/control_button_text_selector</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
